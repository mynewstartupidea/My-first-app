# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Shopify App (get from partners.shopify.com)
SHOPIFY_API_KEY=your_shopify_client_id
SHOPIFY_API_SECRET=your_shopify_client_secret
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,write_customers,read_checkouts,write_checkouts,read_products
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# WhatsApp BSP (add when ready)
WHATSAPP_BSP=mock
WHATSAPP_API_KEY=your_bsp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Cron security
CRON_SECRET=generate_a_random_secret_here
